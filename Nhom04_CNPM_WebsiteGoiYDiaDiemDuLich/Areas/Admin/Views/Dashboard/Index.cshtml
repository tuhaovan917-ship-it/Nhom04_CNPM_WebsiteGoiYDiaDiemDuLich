@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-4">
    <i class="fa fa-chart-bar"></i> Thống kê hệ thống
</h2>

<div class="row">

    <div class="col-md-3">
        <div class="card shadow-sm text-center">
            <div class="card-body">
                <h5>Địa điểm</h5>
                <h2>@ViewBag.TotalPlaces</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm text-center">
            <div class="card-body">
                <h5>Người dùng</h5>
                <h2>@ViewBag.TotalUsers</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm text-center">
            <div class="card-body">
                <h5>Bình luận</h5>
                <h2>@ViewBag.TotalReviews</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm text-center">
            <div class="card-body">
                <h5>Bài viết</h5>
                <h2>@ViewBag.TotalBlogs</h2>
            </div>
        </div>
    </div>

</div>
