@model Nhom04_CNPM_WebsiteGoiYDiaDiemDuLich.Models.User
@{
    ViewBag.Title = "Chỉnh sửa người dùng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h3 class="fw-bold mb-3">Chỉnh sửa người dùng</h3>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.UserId)

    <div class="mb-3">
        <label>Họ tên</label>
        @Html.TextBoxFor(m => m.FullName,
            new { @class = "form-control" })
    </div>

    <div class="mb-3">
        <label>Email</label>
        @Html.TextBoxFor(m => m.Email,
            new { @class = "form-control", @readonly = "readonly" })
    </div>

    <div class="mb-3">
        <label>Quyền</label>
        @Html.DropDownListFor(
            m => m.Role,
            (SelectList)ViewBag.Roles,
            new { @class = "form-select" }
        )
    </div>

    <div class="mb-3 form-check">
        @Html.CheckBoxFor(m => m.IsEmailConfirmed,
            new { @class = "form-check-input" })
        <label class="form-check-label">
            Đã xác minh email
        </label>
    </div>

    <button class="btn btn-success">
        <i class="fa fa-save"></i> Lưu
    </button>

    <a href="/Admin/Users" class="btn btn-secondary">
        Quay lại
    </a>
}
