@{
    ViewBag.Title = "Đăng nhập";
}

<div class="container mt-5" style="max-width: 500px;">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <h3 class="text-center fw-bold mb-4">Đăng nhập</h3>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            <form action="/Account/Login" method="post">

                <div class="mb-3">
                    <label class="form-label fw-bold">Email</label>
                    <input type="email" name="Email" class="form-control form-control-lg"
                           placeholder="Nhập email..." required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Mật khẩu</label>
                    <input type="password" name="Password" class="form-control form-control-lg"
                           placeholder="Nhập mật khẩu..." required />
                </div>

                <div class="d-flex justify-content-between mb-3">
                    <a href="/Account/ForgotPassword">Quên mật khẩu?</a>
                </div>

                <button class="btn btn-primary btn-lg w-100" type="submit">
                    <i class="fa fa-sign-in-alt"></i> Đăng nhập
                </button>

                <div class="text-center mt-3">
                    Chưa có tài khoản?
                    <a href="/Account/Register">Đăng ký ngay</a>
                </div>
            </form>

            <hr />

            <div class="text-center">
                @*<p class="mb-2">Hoặc tiếp tục bằng:</p>

                <a href="#" class="btn btn-outline-danger w-100 mb-2">
                    <i class="fab fa-google"></i> Đăng nhập bằng Google
                </a>

                <a href="#" class="btn btn-outline-primary w-100">
                    <i class="fab fa-facebook"></i> Đăng nhập bằng Facebook
                </a>*@

                <div class="mt-3">
                    <a href="/?guest=true" class="text-decoration-none">
                        Tiếp tục như khách
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>
