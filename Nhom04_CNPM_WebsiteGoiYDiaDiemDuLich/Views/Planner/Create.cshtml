@{
    ViewBag.Title = "Tạo kế hoạch du lịch";
    var places = ViewBag.Places as List<Nhom04_CNPM_WebsiteGoiYDiaDiemDuLich.Models.Place>;
}

<div class="container py-4" style="max-width: 900px;">

    <h2 class="fw-bold mb-4"><i class="fa fa-calendar-check"></i> Tạo kế hoạch du lịch</h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @using (Html.BeginForm("CreatePlan", "Planner", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <h5 class="fw-bold mb-3">1. Chọn thời gian</h5>
        <div class="row mb-4">
            <div class="col-md-6">
                <label>Ngày bắt đầu</label>
                <input type="date" name="StartDate" id="start" class="form-control form-control-lg" required />
            </div>
            <div class="col-md-6">
                <label>Ngày kết thúc</label>
                <input type="date" name="EndDate" id="end" class="form-control form-control-lg" required />
            </div>
        </div>

        <h5 class="fw-bold mb-3">2. Chọn địa điểm cho từng ngày</h5>

        <div id="dayContainer"></div>

        <script>
            document.getElementById("end").addEventListener("change", generateDays);
            document.getElementById("start").addEventListener("change", generateDays);

            function generateDays() {
                var s = document.getElementById("start").value;
                var e = document.getElementById("end").value;

                if (!s || !e) return;

                var start = new Date(s);
                var end = new Date(e);

                if (end < start) return;

                var html = "";
                var dayNo = 1;

                for (var d = new Date(start); d <= end; d.setDate(d.getDate() + 1)) {

                    html += `
                        <div class="card border mb-3 p-3">
                            <h6 class="fw-bold">Ngày ${dayNo} (${d.toLocaleDateString()})</h6>

                            <select class="form-select" name="DayPlaceIds">
                                <option value="">-- Chọn địa điểm --</option>
                                ${placesHtml()}
                            </select>
                        </div>
                    `;
                    dayNo++;
                }

                document.getElementById("dayContainer").innerHTML = html;
            }

            function placesHtml() {
                return `
                    @foreach (var p in places)
                    {
                        @:<option value="@p.PlaceId">@p.Title</option>
                    }
                `;
            }
        </script>

        <h5 class="fw-bold mt-4 mb-3">3. Chi phí</h5>
        <input type="text" name="Title" class="form-control mb-3" placeholder="Tên kế hoạch (tuỳ chọn)" />

        <label>Di chuyển</label>
        <input type="number" name="MoveCost" class="form-control mb-3" />

        <label>Lưu trú</label>
        <input type="number" name="StayCost" class="form-control mb-3" />

        <label>Ăn uống</label>
        <input type="number" name="FoodCost" class="form-control mb-3" />

        <label>Khác</label>
        <input type="number" name="OtherCost" class="form-control mb-4" />

        <div class="text-center">
            <button class="btn btn-success btn-lg px-5">Lưu kế hoạch</button>
        </div>
    }
</div>
