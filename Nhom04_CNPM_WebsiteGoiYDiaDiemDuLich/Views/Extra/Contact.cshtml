            @using (Html.BeginForm("Contact", "Extra", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">Họ tên</label>
                    <input name="FullName"
                           value="@Request["FullName"]"
                           class="form-control form-control-lg"
                           placeholder="Nhập họ tên" />
                    @Html.ValidationMessage("FullName", "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input name="Email"
                           type="email"
                           value="@Request["Email"]"
                           class="form-control form-control-lg"
                           placeholder="example@gmail.com" />
                    @Html.ValidationMessage("Email", "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    <label class="form-label">Nội dung</label>
                    <textarea name="Message"
                              rows="4"
                              class="form-control form-control-lg"
                              placeholder="Nhập nội dung liên hệ">@Request["Message"]</textarea>
                    @Html.ValidationMessage("Message", "", new { @class = "text-danger" })
                </div>

                <button class="btn btn-primary btn-lg">
                    <i class="fa fa-paper-plane"></i> Gửi liên hệ
                </button>
            }

        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <h5 class="fw-bold mb-3">Thông tin hỗ trợ</h5>

            <p><i class="fa fa-map-marker"></i> 123 Đường ABC, TP. Hồ Chí Minh</p>
            <p><i class="fa fa-envelope"></i> support@travel.com</p>
            <p><i class="fa fa-phone"></i> 0123 456 789</p>

        </div>
    </div>

</div>